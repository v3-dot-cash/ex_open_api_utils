{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@/generated/*": ["generated/*"],
      "@/samples/*": ["../client_samples/typescript/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "generated/**/*.ts",
    "../client_samples/typescript/**/*.ts",
    "vitest.config.ts",
    "vitest.setup.ts"
  ]
}
